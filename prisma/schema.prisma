generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// CONTAS DE MARKETPLACE
// ========================
model Account {
  id           String   @id @default(cuid())
  platform     Platform
  platformId   String
  nickname     String?
  email        String?
  accessToken  String
  refreshToken String?
  tokenExpires DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  products     Product[]
  syncLogs     SyncLog[]
  adCampaigns  AdCampaign[]

  @@unique([platform, platformId])
  @@map("accounts")
}

enum Platform {
  MERCADO_LIVRE
  SHOPEE
  TIKTOK_SHOP
  AMAZON
}

// ========================
// PRODUTOS
// ========================
model Product {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platformItemId  String
  title           String
  sku             String?
  price           Float
  currency        String   @default("BRL")
  stock           Int      @default(0)
  status          String?
  categoryId      String?
  thumbnail       String?
  permalink       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      OrderItem[]

  @@unique([accountId, platformItemId])
  @@map("products")
}

// ========================
// PEDIDOS / VENDAS
// ========================
model Order {
  id                 String      @id @default(cuid())
  accountId          String
  account            Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platformOrderId    String
  status             String
  totalAmount        Float
  currency           String      @default("BRL")

  productCost        Float       @default(0)
  shippingCost       Float       @default(0)
  sellerShippingCost Float       @default(0)
  platformFee        Float       @default(0)
  taxAmount          Float       @default(0)
  discount           Float       @default(0)

  buyerNickname      String?
  shippingId         String?
  packId             String?

  orderDate          DateTime
  paidDate           DateTime?
  shippedDate        DateTime?
  deliveredDate      DateTime?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items              OrderItem[]

  @@unique([accountId, platformOrderId])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  platformItemId  String
  title           String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  sku             String?

  @@map("order_items")
}

// ========================
// METRICAS DIARIAS (cache para dashboard)
// ========================
model DailyMetric {
  id              String   @id @default(cuid())
  platform        Platform
  date            DateTime @db.Date

  revenue         Float    @default(0)
  cost            Float    @default(0)
  tax             Float    @default(0)
  platformFee     Float    @default(0)
  shippingCost    Float    @default(0)
  discount        Float    @default(0)
  margin          Float    @default(0)

  totalOrders     Int      @default(0)
  totalUnits      Int      @default(0)
  cancelledOrders Int      @default(0)
  avgTicket       Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([platform, date])
  @@map("daily_metrics")
}

// ========================
// LOGS DE SINCRONIZACAO
// ========================
model SyncLog {
  id          String     @id @default(cuid())
  accountId   String
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  syncType    String
  status      SyncStatus
  recordsSync Int        @default(0)
  errorMsg    String?
  startedAt   DateTime   @default(now())
  finishedAt  DateTime?

  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

// ========================
// CONFIGURACOES DO APP
// ========================
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ========================
// CUSTOS DE PRODUTO (SKU)
// ========================
model ProductCost {
  id        String   @id @default(cuid())
  sku       String   @unique
  title     String?
  cost      Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_costs")
}

// ========================
// ESTOQUE & COMPRAS
// ========================
model StockItem {
  id              String   @id @default(cuid())
  sku             String   @unique
  title           String?
  currentStock    Int      @default(0)
  cost            Float    @default(0)
  salePrice       Float    @default(0)
  leadTimeDays    Int      @default(7)    // Tempo do fornecedor (dias)
  safetyStockDays Int      @default(30)   // Estoque de seguranca (dias de reserva)
  minStock        Int      @default(0)    // Estoque minimo calculado
  reorderPoint    Int      @default(0)    // Ponto de reposicao
  avgDailySales   Float    @default(0)    // Media de vendas/dia
  abcClass        String?  // A, B ou C
  supplier        String?  // Nome do fornecedor
  category        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchases       Purchase[]

  @@map("stock_items")
}

model Purchase {
  id            String    @id @default(cuid())
  stockItemId   String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  quantity      Int
  unitCost      Float
  totalCost     Float
  supplier      String?
  notes         String?
  status        String    @default("pending") // pending, received, cancelled
  orderDate     DateTime  @default(now())
  receivedDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("purchases")
}

// ========================
// CAMPANHAS DE ADS
// ========================
model AdCampaign {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform      Platform
  campaignId    String   // ID da campanha na plataforma
  campaignName  String?
  status        String?  // active, paused, ended
  dailyBudget   Float    @default(0)
  totalBudget   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  metrics       AdMetric[]

  @@unique([accountId, campaignId])
  @@map("ad_campaigns")
}

// Metricas diarias de ADS por campanha
model AdMetric {
  id            String     @id @default(cuid())
  campaignId    String
  campaign      AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date          DateTime   @db.Date

  impressions   Int        @default(0)
  clicks        Int        @default(0)
  spend         Float      @default(0)  // Investimento (R$)
  revenue       Float      @default(0)  // Receita gerada pelos ads
  orders        Int        @default(0)  // Vendas geradas pelos ads

  // Metricas calculadas
  cpc           Float      @default(0)  // Custo por clique
  ctr           Float      @default(0)  // Click-through rate (%)
  acos          Float      @default(0)  // Advertising Cost of Sales (%)
  roas          Float      @default(0)  // Return on Ad Spend

  itemId        String?    // ID do produto anunciado
  sku           String?    // SKU do produto

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([campaignId, date])
  @@map("ad_metrics")
}

// Metricas diarias de ADS agregadas por plataforma
model AdDailyTotal {
  id            String   @id @default(cuid())
  platform      Platform
  date          DateTime @db.Date

  impressions   Int      @default(0)
  clicks        Int      @default(0)
  spend         Float    @default(0)
  revenue       Float    @default(0)
  orders        Int      @default(0)
  cpc           Float    @default(0)
  acos          Float    @default(0)
  tacos         Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([platform, date])
  @@map("ad_daily_totals")
}
