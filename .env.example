# === BANCO DE DADOS (Neon - gratis) ===
# Crie uma conta em https://neon.tech e copie a connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# === MERCADO LIVRE ===
# Crie um app em https://developers.mercadolivre.com.br/devcenter
ML_CLIENT_ID="seu_app_id_aqui"
ML_CLIENT_SECRET="seu_app_secret_aqui"
ML_REDIRECT_URI="https://seu-dominio.vercel.app/api/auth/mercadolivre/callback"

# === APP ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-uma-string-aleatoria-aqui"
